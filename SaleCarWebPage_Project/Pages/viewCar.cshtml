@page "{id:int?}"
@model SaleCarWebPage_Project.Pages.viewCarModel
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Car != null
        ? $"{Model.Car?.Model?.Brand?.BrandName} {Model.Car?.Model?.ModelName}"
        : "As Minhas Mensagens";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/viewCar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/favoritesBottom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/messageBox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/proposal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/global/styles.css" asp-append-version="true" />

}

<main class="car-view-container">
    @if (Model.Car == null)
    {
        <div class="inbox-container">
            <header class="inbox-premium-header">
                <h2 class="section-title">
                    <i class="fa-solid fa-envelope-open-text"></i> Centro de Mensagens
                </h2>
                <p class="section-subtitle">Acompanhe as suas negociações e conversas ativas</p>
            </header>
            <div class="inbox-content">
                <partial name="_messageBox" model="Model.MessageBoxData" />
            </div>
        </div>
    }
    else
    {
        <div class="car-main-layout">

            @* LADO ESQUERDO *@
            <div class="car-content-area">
                <div class="car-image-frame">
                    <img src="@(Model.Car?.ImageUrl ?? "/img/cars/default-car.jpg")"
                         alt="@Model.Car?.Model?.ModelName" class="main-car-img" />
                    <div class="car-status-badges">
                        @if (Model.Car?.IsApproved == true)
                        {
                            <span class="badge-approved">
                                <i class="fa-solid fa-check-double"></i> Verificado
                            </span>
                        }
                        <span class="badge-category">@Model.Car?.Category</span>
                    </div>
                </div>

                <section class="details-section">
                    <h3 class="section-title">
                        <i class="fa-solid fa-microchip"></i> Especificações Técnicas
                    </h3>
                    <div class="details-grid">
                        <div class="detail-box">
                            <span class="detail-label">Matrícula</span>
                            <span class="detail-value">@Model.Car?.PlateNumber</span>
                        </div>
                        <div class="detail-box">
                            <span class="detail-label">Cor Exterior</span>
                            <span class="detail-value">@Model.Car?.CarColor</span>
                        </div>
                        <div class="detail-box">
                            <span class="detail-label">Tara (Peso)</span>
                            <span class="detail-value">@Model.Car?.CarTare.ToString("N0") kg</span>
                        </div>
                        <div class="detail-box">
                            <span class="detail-label">Cilindrada</span>
                            <span class="detail-value">@Model.Car?.EngineCapacity cc</span>
                        </div>
                    </div>
                </section>

                <section class="details-section">
                    <h3 class="section-title">
                        <i class="fa-solid fa-location-dot"></i> Localização do Veículo
                    </h3>
                    <div class="address-card">
                        @if (Model.Car?.Provider?.Address != null)
                        {
                            <p class="address-main">@Model.Car.Provider.Address.Locate</p>
                            <p class="address-sub">
                                @Model.Car.Provider.Address.City, @Model.Car.Provider.Address.Country
                            </p>
                            <small class="postal-code">C.P: @Model.Car.Provider.Address.PostalCode</small>
                        }
                        else
                        {
                            <p class="no-location">Localização sob consulta</p>
                        }
                    </div>
                </section>
            </div>

            @* LADO DIREITO: SIDEBAR *@
            <aside class="car-specs-sidebar">
                <header class="specs-header">
                    <span class="brand-label">@Model.Car?.Model?.Brand?.BrandName</span>
                    <h1 class="car-title">@Model.Car?.Model?.ModelName</h1>
                    <div class="price-container">
                        <span class="currency">€</span>
                        <span class="amount">@Model.Car?.CarPrice.ToString("N0")</span>
                    </div>
                </header>

                <div class="quick-specs-grid">
                    <div class="q-spec">
                        <i class="fa-solid fa-calendar-check"></i>
                        <div class="q-spec-data"><label>Ano</label><span>@Model.Car?.Year</span></div>
                    </div>
                    <div class="q-spec">
                        <i class="fa-solid fa-gauge-high"></i>
                        <div class="q-spec-data"><label>Kms</label><span>@Model.Car?.Kilometers.ToString("N0")</span></div>
                    </div>
                </div>

                <div class="seller-card">
                    <div class="seller-header">
                        <div class="seller-meta">
                            <span class="seller-type">Vendedor</span>
                            <span class="seller-name">@(Model.Car?.Provider?.NameProvider ?? "Particular")</span>
                        </div>
                    </div>

                    @* ÁREA PRIVADA DE NEGOCIAÇÃO *@
                    @if (User.Identity!.IsAuthenticated)
                    {                        
                        <div class="negotiation-section">
                            <h4 class="owner-title"><i class="fa-solid fa-handshake"></i> Negociação de Valores</h4>
                            
                            @if (!Model.CanEdit)
                            {
                                <button type="button" class="btn-make-offer w-100 mb-3" data-bs-toggle="modal" data-bs-target="#offerModal">
                                    <i class="fa-solid fa-plus"></i> NOVA PROPOSTA
                                </button>
                            }                           
                            
                            <div class="view-negotiations-link mt-2">
                                <a asp-page="/Negotiations" asp-route-carId="@Model.Car?.CarId" class="btn-manage-negotiations">
                                    <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                    <span>GERIR NEGOCIAÇÕES</span>
                                </a>
                            </div>
                        </div>

                        <hr class="luxury-divider" />

                        @* 2. ÁREA DE MENSAGENS (Privada) *@
                        <div class="chat-section">
                            <h4 class="owner-title"><i class="fa-solid fa-comments"></i> Mensagens Privadas</h4>
                            <partial name="_messageBox" model="Model.MessageBoxData" />
                        </div>
                    }
                    else
                    {
                        <div class="login-notice">
                            <p>Faça login para propor valores ou contactar o vendedor.</p>
                            <a href="/auth" class="btn-luxury-submit">LOGIN / REGISTO</a>
                        </div>
                    }
                </div>

                <div class="favorite-action-premium">
                    <button class="btn-garage @(Model.Car?.IsFavorite == true ? "is-in-garage" : "")"
                            onclick="toggleGarage(@(Model.Car?.CarId ?? 0), this)">
                        <i class="@(Model.Car?.IsFavorite == true ? "fa-solid fa-gem" : "fa-regular fa-gem")"></i>
                        <span>@(Model.Car?.IsFavorite == true ? "Na minha Garagem" : "Guardar na Garagem")</span>
                    </button>
                </div>
            </aside>
        </div>
    }
</main>

@* MODAL DE PROPOSTA *@
@if (Model.Car != null && !Model.CanEdit)
{
    <div class="modal fade" id="offerModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm-custom">
            <div class="modal-content luxury-modal-slim">
                <div class="modal-body">
                    <button type="button" class="btn-close-luxury" data-bs-dismiss="modal">×</button>
                    <div class="luxury-form-header">
                        <input type="hidden" id="hiddenCarId" value="@Model.Car.CarId" />
                        <h2 class="luxury-title">Enviar Proposta</h2>
                    </div>
                    <div class="luxury-input-group">
                        <label>Valor (€)</label>
                        <input type="number" id="offerValue" class="luxury-input main-value" value="@Model.Car.CarPrice" step="500">
                    </div>
                    <div class="luxury-input-group">
                        <label>Contacto</label>
                        <input type="tel" id="offerContact" class="luxury-input" placeholder="9xx xxx xxx">
                    </div>
                    <button type="button" class="btn-luxury-submit" onclick="submitOffer()">ENVIAR PROPOSTA</button>
                </div>
            </div>
        </div>
    </div>
}

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        async function toggleGarage(carId, btn) {
            const isAuthenticated = @(User.Identity.IsAuthenticated.ToString().ToLower());
            if (!isAuthenticated) {
                toastr.warning("Inicie sessão primeiro.");
                return;
            }
            try {
                const response = await fetch(`?handler=ToggleFavorite`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify(carId)
                });
                if (response.ok) { location.reload(); }
            } catch (error) { console.error(error); }
        }
    </script>
    <script src="~/js/submitOffer.js" asp-append-version="true"></script>
}
}