@page "{id:int}"
@model SaleCarWebPage_Project.Pages.viewCarModel
@{
    Layout = "_Layout";
    ViewData["Title"] = $"{Model.Car?.Model?.Brand?.BrandName} {Model.Car?.Model?.ModelName}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/viewCar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/favoritesBottom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/messageBox.css" asp-append-version="true" />
}


<main class="car-view-container">
    <div class="car-main-layout">
        
        @* LADO ESQUERDO: GALERIA E DETALHES EXTENSOS *@
        <div class="car-content-area">
            <div class="car-image-frame">
                <img src="@(Model.Car?.ImageUrl ?? "/img/cars/default-car.jpg")" alt="@Model.Car?.Model?.ModelName" class="main-car-img" />
                <div class="car-status-badges">
                    @if (Model.Car?.IsApproved == true)
                    {
                        <span class="badge-approved"><i class="fa-solid fa-check-double"></i> Verificado</span>
                    }
                    <span class="badge-category">@Model.Car?.Category</span>
                </div>
            </div>

            @* Painel de Informação Técnica Detalhada *@
            <div class="details-section">
                <h3 class="section-title"><i class="fa-solid fa-microchip"></i> Especificações Técnicas</h3>
                <div class="details-grid">
                    <div class="detail-box">
                        <span class="detail-label">Matrícula</span>
                        <span class="detail-value">@Model.Car?.PlateNumber</span>
                    </div>
                    <div class="detail-box">
                        <span class="detail-label">Cor Exterior</span>
                        <span class="detail-value">@Model.Car?.CarColor</span>
                    </div>
                    <div class="detail-box">
                        <span class="detail-label">Tara (Peso)</span>
                        <span class="detail-value">@Model.Car?.CarTare.ToString("N0") kg</span>
                    </div>
                    <div class="detail-box">
                        <span class="detail-label">Cilindrada</span>
                        <span class="detail-value">@Model.Car?.EngineCapacity cc</span>
                    </div>
                </div>
            </div>

            @* Localização do Veículo (Address Entity) *@
            <div class="details-section">
                <h3 class="section-title"><i class="fa-solid fa-location-dot"></i> Localização do Veículo</h3>
                <div class="address-card">
                    <p><strong>@Model.Car?.Provider?.Address?.Locate</strong></p>
                    <p>@Model.Car?.Provider?.Address?.City, @Model.Car?.Provider?.Address?.Country</p>
                    <small>C.P: @Model.Car?.Provider?.Address?.PostalCode</small>
                </div>
            </div>
        </div>

        @* LADO DIREITO: SIDEBAR PREMIUM (AÇÕES E DADOS RÁPIDOS) *@
        <aside class="car-specs-sidebar">
            <div class="specs-header">
                <span class="brand-label">@Model.Car?.Model?.Brand?.BrandName</span>
                <h1>@Model.Car?.Model?.ModelName</h1>
                <div class="price-container">
                    <span class="currency">€</span>
                    <span class="amount">@Model.Car?.CarPrice.ToString("N0")</span>
                </div>
            </div>

            <div class="quick-specs-grid">
                <div class="q-spec"><i class="fa-solid fa-calendar-check"></i> <div><label>Ano</label><span>@Model.Car?.Year</span></div></div>
                <div class="q-spec"><i class="fa-solid fa-gauge-high"></i> <div><label>Kms</label><span>@Model.Car?.Kilometers.ToString("N0") km</span></div></div>
                <div class="q-spec"><i class="fa-solid fa-gas-pump"></i> <div><label>Combustível</label><span>@Model.Car?.TypeOfFuel</span></div></div>
                <div class="q-spec"><i class="fa-solid fa-circle-dot"></i> <div><label>Caixa</label><span>@Model.Car?.Transmission</span></div></div>
            </div>
            
            <div class="seller-card">
                <div class="seller-header">
                    <div class="seller-avatar-init">@Model.Car?.Provider?.NameProvider.Substring(0, 1)</div>
                    <div class="seller-meta">
                        <span class="seller-type">Vendedor Profissional</span>
                        <span class="seller-name">@Model.Car?.Provider?.NameProvider</span>
                    </div>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.Car?.Provider?.CompanyName))
                {
                    <p class="company-name"><i class="fa-solid fa-building"></i> @Model.Car?.Provider?.CompanyName</p>
                }

                @* Botão de Proposta *@
                <div class="offer-container" style="margin: 20px 0;">
                    <button type="button" class="btn-make-offer" data-bs-toggle="modal" data-bs-target="#offerModal">
                        <i class="fa-solid fa-hand-holding-dollar"></i> FAZER PROPOSTA OFICIAL
                    </button>
                </div>

                <partial name="_messageBox" model="Model.MessageBoxData" />
            </div>

            <div class="favorite-action-premium">
                <button class="btn-garage @(Model.Car?.IsFavorite == true ? "is-in-garage" : "")"
                        onclick="toggleGarage(@Model.Car?.CarId, this)">
                    <i class="@(Model.Car?.IsFavorite == true ? "fa-solid fa-gem" : "fa-regular fa-gem")"></i>
                    <span class="fav-text">
                        @(Model.Car?.IsFavorite == true ? "Na minha Garagem" : "Guardar na Garagem")
                    </span>
                </button>
            </div>
        </aside>
    </div>
</main>

@* MODAL DE PROPOSTA (Fora do main para evitar conflitos de z-index) *@
<div class="modal fade" id="offerModal" tabindex="-1" aria-labelledby="offerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content luxury-modal">
            <div class="modal-header" style="border-bottom: 1px solid rgba(212, 175, 55, 0.2);">
                <h5 class="modal-title" id="offerModalLabel" style="color: #d4af37; letter-spacing: 2px;">FORMALIZAR PROPOSTA</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 30px;">
                <div class="mb-4">
                    <label class="form-label" style="color: #888; font-size: 0.8rem; text-transform: uppercase;">Valor da Oferta (€)</label>
                    <input type="number" id="offerValue" class="form-control input-premium" value="@Model.Car?.CarPrice" style="font-size: 1.5rem; font-weight: 700; color: #d4af37 !important;">
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="color: #888; font-size: 0.8rem; text-transform: uppercase;">O seu NIF</label>
                        <input type="text" id="offerNif" class="form-control input-premium" placeholder="250 000 000">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="color: #888; font-size: 0.8rem; text-transform: uppercase;">Contacto</label>
                        <input type="tel" id="offerContact" class="form-control input-premium" placeholder="912 345 678">
                    </div>
                </div>
                <p style="font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-top: 15px;">
                    * Ao submeter, o vendedor receberá uma notificação oficial com os seus dados para análise.
                </p>
            </div>
            <div class="modal-footer" style="border-top: none; padding-bottom: 30px;">
                <button type="button" class="btn-gold-action" style="margin: 0 auto; min-width: 200px;" onclick="submitOffer()">
                    SUBMETER OFERTA
                </button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        async function toggleGarage(carId, btn) {
            // Verifica se o utilizador está logado antes de tentar o AJAX
            const isAuthenticated = @(User.Identity.IsAuthenticated.ToString().ToLower());

            if (!isAuthenticated) {
                toastr.warning("Por favor, faça login para guardar carros nos seus favoritos.");
                setTimeout(() => { window.location.href = '/auth'; }, 2000);
                return;
            }

            if (carId <= 0) return;

            try {
                const response = await fetch(`?handler=ToggleFavorite&carId=${carId}`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                if (response.ok) {
                    const icon = btn.querySelector('i');
                    btn.classList.toggle('is-in-garage');

                    if (btn.classList.contains('is-in-garage')) {
                        icon.classList.replace('fa-regular', 'fa-solid');
                        toastr.success("Adicionado aos favoritos!");
                    } else {
                        icon.classList.replace('fa-solid', 'fa-regular');
                        toastr.info("Removido dos favoritos.");
                    }
                }
            } catch (error) {
                console.error("Erro na ligação:", error);
            }
        }

                document.addEventListener("DOMContentLoaded", function() {
            const chatContainer = document.getElementById("chat-container");
            if (chatContainer) {
                chatContainer.scrollTop = chatContainer.scrollHeight;
            }
        });

        function submitOffer() {
            const value = document.getElementById("offerValue").value;
            const nif = document.getElementById("offerNif").value;
            const contact = document.getElementById("offerContact").value;

            if(!nif || !value || !contact) {
                toastr.error("Por favor, preencha todos os campos da proposta.");
                return;
            }

            // Aqui farias o teu POST para o servidor
            toastr.success("Proposta enviada com sucesso!");
            bootstrap.Modal.getInstance(document.getElementById('offerModal')).hide();
        }
    </script>
}
