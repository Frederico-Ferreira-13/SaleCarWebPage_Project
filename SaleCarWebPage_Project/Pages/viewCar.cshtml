@page "{id:int?}"
@model SaleCarWebPage_Project.Pages.viewCarModel
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Car != null
        ? $"{Model.Car?.Model?.Brand?.BrandName} {Model.Car?.Model?.ModelName}"
        : "As Minhas Mensagens";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/viewCar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/favoritesBottom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/messageBox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/proposal.css" asp-append-version="true" />    
    <link rel="stylesheet" href="~/css/global/styles.css" asp-append-version="true" />
}

<main class="car-view-container">
    @if (Model.Car == null)
    {
        <div class="alert alert-warning shadow-sm">
            <i class="fa-solid fa-circle-exclamation"></i> Veículo não encontrado ou indisponível.
        </div>
    }
    else
    {
        <div class="car-main-layout">
            <div class="car-content-area">
                
                <div class="car-hero-section">
                    <div class="car-image-frame">
                        <img src="@(Model.Car?.ImageUrl ?? "/img/cars/default-car.jpg")" alt="Imagem do Veículo" class="main-car-img" />
                        <div class="car-badges-overlay">
                            @if (Model.Car?.IsApproved == true)
                            {
                                <span class="badge-premium gold"><i class="fa-solid fa-crown"></i> Verificado</span>
                            }
                            <span class="badge-premium dark">@Model.Car?.Category</span>
                        </div>
                    </div>
                </div>

                <section class="info-section">
                    <h3 class="section-title"><i class="fa-solid fa-gears"></i> Ficha Técnico</h3>
                    <div class="specs-full-grid">
                        <div class="spec-item">
                            <i class="fa-solid fa-fingerprint"></i>
                            <div class="spec-data">
                                <label>Matrícula</label>
                                <span>@Model.Car?.PlateNumber</span>
                            </div>
                        </div>
                        <div class="spec-item">
                            <i class="fa-solid fa-gauge"></i>
                            <div class="spec-data">
                                <label>Cilindrada</label>
                                <span>@Model.Car?.EngineCapacity cc</span>
                            </div>
                        </div>
                        <div class="spec-item">
                            <i class="fa-solid fa-palette"></i>
                            <div class="spec-data">
                                <label>Cor Exterior</label>
                                <span>@Model.Car?.CarColor</span>
                            </div>
                        </div>
                        <div class="spec-item">
                            <i class="fa-solid fa-weight-hanging"></i>
                            <div class="spec-data">
                                <label>Peso (Tara)</label>
                                <span>@Model.Car?.CarTare.ToString("N0") kg</span>
                            </div>
                        </div>
                        <div class="spec-item">
                            <i class="fa-solid fa-calendar-days"></i>
                            <div class="spec-data">
                                <label>Ano de Registo</label>
                                <span>@Model.Car?.Year</span>
                            </div>
                        </div>
                        <div class="spec-item">
                            <i class="fa-solid fa-road"></i>
                            <div class="spec-data">
                                <label>Quilometragem</label>
                                <span>@Model.Car?.Kilometers.ToString("N0") km</span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="info-section">
                    <h3 class="section-title"><i class="fa-solid fa-map-location-dot"></i> Localização</h3>
                    <div class="location-card-premium">
                        @if (Model.Car?.Provider?.Address != null)
                        {
                            <div class="loc-icon"><i class="fa-solid fa-location-dot"></i></div>
                            <div class="loc-text">
                                <p class="city">@Model.Car.Provider.Address.City, @Model.Car.Provider.Address.Country</p>
                                <p class="street">@Model.Car.Provider.Address.Locate</p>
                                <span class="zip">CP: @Model.Car.Provider.Address.PostalCode</span>
                            </div>
                        }
                        else
                        {
                            <p class="no-data">Localização disponível sob pedido ao vendedor.</p>
                        }
                    </div>
                </section>
            </div>

            <aside class="car-specs-sidebar">
                <div class="sidebar-sticky-content">
                    
                    <div class="price-header-card">
                        <span class="brand-tag">@Model.Car?.Model?.Brand?.BrandName</span>
                        <h1 class="model-title">@Model.Car?.Model?.ModelName</h1>
                        <div class="main-price">@Model.Car?.CarPrice.ToString("N0") <small>€</small></div>
                    </div>

                    @if (User.Identity!.IsAuthenticated)
                    {
                        <div class="interaction-stack">
                            
                            <div class="action-card proposal-zone shadow-sm">
                                <h4 class="card-subtitle"><i class="fa-solid fa-hand-holding-dollar"></i> Negociar Valor</h4>
                                
                                @if (!Model.CanEdit)
                                {
                                    <div class="quick-proposal-box">
                                        <div class="input-group-premium">
                                            <input type="number" id="quick-offer-input" class="form-control-premium" value="@Model.Car?.CarPrice" step="500" />
                                            <button class="btn-action-gold" onclick="submitQuickOffer()">Enviar Oferta</button>
                                        </div>
                                    </div>
                                }
                                
                                <div class="history-container mt-3">
                                    <partial name="_proposalBox" model="Model.ProposalBoxData" />
                                </div>
                            </div>

                            <div class="action-card message-zone shadow-sm">
                                <div class="luxury-tabs-row">
                                    <button class="luxury-tab active" onclick="switchLuxuryTab('history', this)">
                                        <i class="fa-solid fa-history"></i> Histórico
                                    </button>
                                    <button class="luxury-tab" onclick="switchLuxuryTab('new-msg', this)">
                                        <i class="fa-solid fa-pen-to-square"></i> Nova Mensagem
                                    </button>
                                </div>
                                
                                <div id="tab-history" class="tab-content">
                                    <div class="chat-container-fixed">
                                        <partial name="_messageBox" model="Model.MessageBoxData" />
                                    </div>
                                </div>

                                <div id="tab-new-msg" class="tab-content" style="display: none;">
                                    <div class="input-group-premium vertical">
                                        <textarea id="txtMessage" class="form-control-premium" placeholder="Ex: Bom dia, o carro está disponível para test-drive esta semana?"></textarea>
                                        <button class="btn-action-gold mt-2 w-100" onclick="submitNewMessage()">Enviar Mensagem</button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    }
                    else
                    {
                        <div class="auth-required-card">
                            <p>Autentique-se para negociar este veículo ou contactar o vendedor.</p>
                            <a href="/auth" class="btn-action-gold">Login / Registo</a>
                        </div>
                    }

                    <div class="favorite-wrapper mt-3">
                        <button class="btn-garage-toggle @(Model.Car?.IsFavorite == true ? "active" : "")"
                                onclick="toggleGarage(@Model.Car?.CarId)">
                            <i class="fa-solid fa-gem"></i>
                            <span>@(Model.Car?.IsFavorite == true ? "Na minha Garagem" : "Guardar na Garagem")</span>
                        </button>
                    </div>

                </div>
            </aside>
        </div>
    }
</main>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        async function submitQuickOffer() {
            const val = document.getElementById('quick-offer-input').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if(val <= 0) return alert("Insira um valor válido.");

            const response = await fetch('?handler=SubmitProposal', { // Handler ajustado para o nome do C#
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ carId: @Model.Car?.CarId, offerValue: parseFloat(val), contact: "Via Web" })
            });

            if (response.ok) {
                location.reload();
            }
        }

        function focusChat(subject = "") {
            const chatInput = document.querySelector('#txtMessage'); // ID específico do textarea da messageBox
            if(chatInput) {
                if(subject) chatInput.value = subject + ": ";
                chatInput.focus();
                chatInput.scrollIntoView({ behavior: 'smooth' });
            }
        }

        async function toggleGarage(id) {
            // Lógica de AJAX para favoritos
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const res = await fetch('?handler=ToggleFavorite', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(id)
            });
            if(res.ok) location.reload();
        }

        function switchLuxuryTab(tabId, element) {
            document.getElementById('tab-history').style.display = 'none';
            document.getElementById('tab-new-msg').style.display = 'none';
            element.parentElement.querySelectorAll('.luxury-tab').forEach(btn => btn.classList.remove('active'));
            document.getElementById('tab-' + tabId).style.display = 'block';
            element.classList.add('active');
        }
    </script>
}
