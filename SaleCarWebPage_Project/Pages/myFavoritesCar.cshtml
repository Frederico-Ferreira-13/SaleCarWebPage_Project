@page
@model SaleCarWebPage_Project.Pages.myFavoritesCarModel
@{
    ViewData["Title"] = "Os Meus Favoritos";
}

@section Styles {
    <link rel="stylesheet" href="~/css/global/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/global/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/myfavoritesCar.css" asp-append-version="true" />
}

@* Token de segurança necessário para chamadas POST via JavaScript *@
@Html.AntiForgeryToken()

<div class="favorites-container">
    <header class="page-header">
        <h1 class="silver-text">Garagem <span class="highlight">Privada</span></h1>
        <p>Os modelos que captaram a sua atenção.</p>
    </header>

    @if (Model.MyFavoriteCar != null && Model.MyFavoriteCar.Any())
    {
        <div class="favorites-grid">
            @foreach (var car in Model.MyFavoriteCar)
            {
                <div class="car-card-premium" id="car-card-@car.CarId">
                    <div class="image-wrapper">
                        @* Correção: Removido parêntese extra no alt *@
                        <img src="@car.ImageUrl" alt="@(car.Model?.Brand?.BrandName) @(car.Model?.ModelName)">
                        <div class="price-tag">@car.CarPrice.ToString("C0")</div>

                        @* Alterado para botão com clique JavaScript para evitar refresh total *@
                        <button type="button" class="remove-fav" onclick="removeFavorite(@car.CarId)">
                            <ion-icon name="trash-outline"></ion-icon>
                        </button>
                    </div>

                    <div class="car-info">
                        <h3>
                            @(car.Model?.Brand?.BrandName ?? "Marca")
                            <span>@(car.Model?.ModelName ?? "Modelo")</span>
                        </h3>
                        <div class="car-specs">
                            <span><ion-icon name="speedometer-outline"></ion-icon> @car.Kilometers km</span>
                            <span><ion-icon name="calendar-outline"></ion-icon> @car.Year</span>
                        </div>

                        <div class="card-footer">
                            <a asp-page="/CarDetails" asp-route-id="@car.CarId" class="btn-silver-small">Ver Detalhes</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <ion-icon name="diamond-outline"></ion-icon>
            <h2>Ainda não tem favoritos</h2>
            <p>Explore a nossa montra e guarde os carros que mais gosta.</p>
            <a asp-page="/Index" class="btn-premium">Explorar Galeria</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        async function removeFavorite(carId) {
            if (!confirm("Deseja remover este veículo da sua garagem?")) return;

            try {
                const response = await fetch('?handler=ToggleFavorite', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({ carId: carId })
                });

                if (response.ok) {
                    const data = await response.json();

                    // Se o servidor confirmar que já não é favorito
                    if (!data.isFavorite) {
                        const card = document.getElementById(`car-card-${carId}`);

                        // Efeito visual de desaparecimento
                        card.style.transform = 'scale(0.8)';
                        card.style.opacity = '0';
                        card.style.transition = 'all 0.4s ease';

                        setTimeout(() => {
                            card.remove();
                            // Se a garagem ficar vazia após remover, recarrega para mostrar o empty-state
                            if (document.querySelectorAll('.car-card-premium').length === 0) {
                                location.reload();
                            }
                        }, 400);

                        toastr.success("Veículo removido com sucesso.");
                    }
                } else {
                    toastr.error("Não foi possível remover o favorito.");
                }
            } catch (error) {
                console.error("Erro ao remover favorito:", error);
                toastr.error("Ocorreu um erro técnico.");
            }
        }
    </script>
}