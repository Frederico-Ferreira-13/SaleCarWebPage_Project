@page
@model SaleCarWebPage_Project.Pages.messagesPageModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Mensagens";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/messageBox.css" asp-append-version="true" />
}

<div style="max-width: 900px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #d4af37; margin-bottom: 30px;">
        <i class="fa-solid fa-comments"></i> As Minhas Mensagens
    </h2>

    @if (!Model.Conversations.Any())
    {
        <div style="text-align: center; color: #aaa; padding: 60px 20px;">
            <i class="fa-solid fa-inbox" style="font-size: 3rem; margin-bottom: 15px; display: block;"></i>
            <p>Ainda não tens mensagens.</p>
        </div>
    }
    else
    {
        int i = 0;
        @foreach (var conv in Model.Conversations)
        {
            var collapseId = $"conv-{conv.CarId}-{conv.OtherPartyId}";
            var lastMsg = conv.MessageBoxData.ChatHistory.OrderByDescending(m => m.SentDate).FirstOrDefault();

            <div class="conv-card">
                @* CABEÇALHO CLICÁVEL *@
                <div onclick="toggleConv('@collapseId')" class="conv-header">

                    @* IMAGEM DO CARRO *@
                    <img src="@conv.CarImage" alt="@conv.CarName" class="conv-car-img" />

                    @* INFO *@
                    <div style="flex: 1; min-width: 0;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span class="conv-title">@conv.CarName</span>
                            <span class="conv-last-date">
                                @(lastMsg?.SentDate.ToString("dd/MM HH:mm") ?? "")
                            </span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 4px;">
                            <span class="conv-user">
                                <i class="fa-solid fa-user"></i>@conv.OtherPartyName
                            </span>
                            @if (lastMsg != null)
                            {
                                <span class="conv-preview-text" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 250px;">
                                    @lastMsg.MessageText
                                </span>
                            }
                        </div>
                    </div>

                    @* SETA *@
                    <i class="fa-solid fa-chevron-down conv-arrow" id="arrow-@collapseId"></i>
                </div>

                @* CONTEÚDO COLAPSÁVEL *@
                <div id="@collapseId" style="display: none; border-top: 1px solid rgba(212,175,55,0.1); background: rgba(0,0,0,0.1);">
                    <div style="padding: 15px;">
                        <partial name="_messageBox" model="conv.MessageBoxData" />
                    </div>
                    <div style="padding: 10px 25px; text-align: right; border-top: 1px solid rgba(255,255,255,0.02);">
                        <a href="/viewCar/@conv.CarId" class="btn-action-luxury" style="font-size: 0.7rem;">
                            <i class="fa-solid fa-external-link"></i> Ver anúncio do veículo
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>

<script>
    function toggleConv(id) {
        const content = document.getElementById(id);
        const arrow = document.getElementById('arrow-' + id);
        const isOpen = content.style.display !== 'none';
        content.style.display = isOpen ? 'none' : 'block';
        arrow.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
    }
</script>