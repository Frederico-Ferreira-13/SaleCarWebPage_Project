@page "{carId:int?}"
@model SaleCarWebPage_Project.Pages.NegotiationsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Negociações Ativas";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/negotiations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/proposal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/messageBox.css" asp-append-version="true" />
}

<div class="negotiations-container">
    <header class="negotiations-header">
        <h2 class="gold-title">
            <i class="fa-solid fa-handshake"></i> NEGOCIAÇÕES ATIVAS
        </h2>
    </header>

    @if (!Model.Negotiations.Any())
    {
        <div class="empty-state">
            <i class="fa-solid fa-folder-open empty-icon"></i>
            <p>Ainda não iniciaste nenhuma negociação.</p>
        </div>
    }
    else
    {
        @foreach (var neg in Model.Negotiations)
        {
            var collapseId = $"neg-{neg.CarId}";
            
            <div class="conv-card">
                <div onclick="toggleConv('@collapseId')" class="conv-header">
                    <div class="car-image-wrapper">
                        <img src="@neg.CarImage" alt="@neg.CarName" class="car-thumb" />
                    </div>
                    <div class="header-info">
                        <div class="header-top-row">
                            <span class="car-name">@neg.CarName</span>
                            <span class="proposal-value">@neg.LastOfferValue.ToString("C0")</span>
                        </div>
                        <div class="header-bottom-row">
                            <span class="user-info">
                                <i class="fa-solid fa-user-circle"></i> @neg.OtherPartyName
                            </span>
                            <span class="negotiation-status @(neg.IsSeller ? "status-seller" : "status-buyer")">
                                @(neg.IsSeller ? "Vendedor" : "Comprador")
                            </span>
                        </div>
                    </div>
                    <i class="fa-solid fa-chevron-down conv-arrow" id="arrow-@collapseId"></i>
                </div>

                <div id="@collapseId" class="conv-content" style="display: none;">
                    <div class="negotiation-grid">
                        <div class="proposal-column">
                            <span class="section-label">Histórico de Ofertas</span>
                            <partial name="_proposalBox" model="neg.ProposalData" />
                        </div>

                        <div class="chat-column">
                            <span class="section-label">Mensagens de Apoio</span>
                            <div class="chat-scroll-area">
                                <partial name="_messageBox" model="neg.MessageBoxData" />
                            </div>
                        </div>
                    </div>

                    <div class="negotiation-footer">
                        <a href="/viewCar/@neg.CarId" class="back-link">
                            <i class="fa-solid fa-arrow-left"></i> Ver Anúncio
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>

<div id="counterModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="modal-header">
            <h5>Fazer Contra-Proposta</h5>
            <span class="close-modal" onclick="closeCounterModal()">×</span>
        </div>
        <div class="modal-body">
            <div class="luxury-input-group">
                <label>Valor da Contra-Proposta (€)</label>
                <input type="number" id="counterValueInput" class="luxury-input main-value"
                       step="1000" placeholder="Ex: 315000" autofocus>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cancel-luxury" onclick="closeCounterModal()">Cancelar</button>
            <button type="button" class="btn-luxury-gold" onclick="submitCounterOffer()">
                <i class="fa-solid fa-paper-plane"></i> Enviar
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleConv(id) {
            const content = document.getElementById(id);
            const arrow = document.getElementById('arrow-' + id);
            const isOpen = content.style.display !== 'none';
            
            content.style.display = isOpen ? 'none' : 'block';
            arrow.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
        }

        let currentSaleId = 0;

        function handleAction(saleId, action) {
            currentSaleId = saleId;

            if (action === 'counter') {
                document.getElementById('counterValueInput').value = '';
                document.getElementById('counterModal').style.display = 'flex';
            }
            else {
                const text = action === 'accept' ? 'ACEITAR' : 'RECUSAR';
                if (confirm(`Tem certeza que deseja ${text} esta proposta?`)) {
                    const handler = action === 'accept' ? 'Accept' : 'Decline';
                    fetch(`?handler=${handler}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify({ saleId: saleId })
                    }).then(r => {
                        if (r.ok) location.reload();
                    });
                }
            }
        }

        function closeCounterModal() {
            document.getElementById('counterModal').style.display = 'none';
        }

        function submitCounterOffer() {
            const value = parseFloat(document.getElementById('counterValueInput').value);
            if (!value || value <= 0) {
                alert("Por favor insira um valor válido!");
                return;
            }

            fetch('?handler=CounterOffer', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ saleId: currentSaleId, counterValue: value })
            }).then(r => {
                if (r.ok) {
                    closeCounterModal();
                    location.reload();
                }
            });
        }

        // Fechar modal ao clicar fora
        document.getElementById('counterModal').addEventListener('click', function(e) {
            if (e.target === this) closeCounterModal();
        });

        function toggleActions(saleId, isLatest) {
            if (!isLatest) return; // Só permite ações na proposta mais recente

            const panel = document.getElementById(`actions-${saleId}`);
            const isVisible = panel.style.display === 'block';

            // Fechar todos os outros painéis primeiro para manter limpo
            document.querySelectorAll('.quick-actions-panel').forEach(p => p.style.display = 'none');

            // Toggle do atual
            panel.style.display = isVisible ? 'none' : 'block';
        }

        function showInlineCounter(saleId) {
            // Esconde os botões normais e mostra o input de valor
            document.querySelector(`#actions-${saleId} .proposal-actions`).style.display = 'none';
            document.getElementById(`inline-counter-${saleId}`).style.display = 'flex';
            document.getElementById(`val-${saleId}`).focus();
        }

        async function submitInlineCounter(saleId) {
            const newValue = document.getElementById(`val-${saleId}`).value;
            if (!newValue || newValue <= 0) {
                alert("Insira um valor válido!");
                return;
            }

            // Aqui usas a tua lógica de fetch que já tinhas no modal
            const response = await fetch('?handler=CounterOffer', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ saleId: saleId, counterValue: parseFloat(newValue) })
            });

            if (response.ok) {
                location.reload(); // Ao recarregar, o novo valor aparecerá com o estilo "counter-value"
            }
        }
    </script>
}