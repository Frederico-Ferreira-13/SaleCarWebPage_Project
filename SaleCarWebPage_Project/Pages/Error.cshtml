@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/error.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/styles.css" asp-append-version="true" />
}

<div class="error-container">
    <article class="error-content">
        <div class="error-icon">
            <i class="fa-solid fa-gear"></i>
        </div>
        
        <h1 class="luxury-text">Performance em <span class="highlight">Ajuste</span></h1>
        
        <p class="error-message">
            Estamos a otimizar os nossos sistemas para lhe garantir uma navegação de alta performance.
            Voltaremos à estrada num instante.
        </p>

        <div class="error-actions">
            <a href="/Index" class="error-btn-main">
                <i class="fa-solid fa-house"></i> Ir para o Stand
            </a>
            <a href="javascript:history.back()" class="btn-back-link">
                <i class="fa-solid fa-chevron-left"></i> Voltar atrás
            </a>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="request-id-tag" style="margin-top: 40px; opacity: 0.3; font-size: 0.7rem;">
                <code>REF: @Model.RequestId</code>
            </div>
        }
    </article>
</div>