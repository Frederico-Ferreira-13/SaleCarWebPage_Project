@page
@model SaleCarWebPage_Project.Pages.SaleCarModel
@{
    ViewData["Title"] = "Anunciar Venda Premium";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/saleCar.css" asp-append-version="true" />
}

<div class="sale-container">
    <div class="luxury-form-card">
        <div class="form-header">
            <h3>ANUNCIAR VEÍCULO</h3>
            <p style="color: #888;">Partilhe a excelência com a nossa comunidade exclusiva.</p>
        </div>

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="form-section-title">Dados do Vendedor & Faturamento</div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Nome da Empresa / Profissional</label>
                    <input type="text" class="form-control input-premium" placeholder="Ex: Stand Luxury S.A." />
                </div>
                <div class="col-md-6 mb-3">
                    <label>NIF (Número de Contribuinte)</label>
                    <input type="text" class="form-control input-premium" placeholder="Ex: 500123456" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label>Telemóvel de Contacto</label>
                    <input type="tel" class="form-control input-premium" placeholder="+351 912 ..." />
                </div>
                <div class="col-md-8 mb-3">
                    <label>Morada de Exibição do Veículo</label>
                    <input type="text" class="form-control input-premium" placeholder="Rua, Cidade, Código Postal" />
                </div>
            </div>

            <div class="form-section-title">Informação Principal</div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Marca</label>
                    <select asp-for="NewCar.Model.BrandId" class="form-control input-premium" asp-items="Model.BrandList">
                        <option value="">Selecione a Marca</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label>Modelo (Texto)</label>
                    <input type="text" asp-for="NewCar.Model.ModelName" class="form-control input-premium" placeholder="Ex: Aventador SVJ" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label>Ano</label>
                    <input asp-for="NewCar.Year" class="form-control input-premium" type="number" />
                </div>
                <div class="col-md-4 mb-3">
                    <label>Preço (€)</label>
                    <input asp-for="NewCar.CarPrice" class="form-control input-premium" type="number" />
                </div>
                <div class="col-md-4 mb-3">
                    <label>Estado</label>
                    <select class="form-control input-premium">
                        <option value="Usado">Usado</option>
                        <option value="Novo">Novo / 0 Km</option>
                    </select>
                </div>
            </div>

            <div class="form-section-title">Especificações Técnicas</div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label>Combustível</label>
                    <select asp-for="NewCar.TypeOfFuel" class="form-control input-premium" asp-items="Model.FuelList"></select>
                </div>
                <div class="col-md-4 mb-3">
                    <label>Transmissão</label>
                    <select asp-for="NewCar.Transmission" class="form-control input-premium" asp-items="Model.TransmissionList"></select>
                </div>
                <div class="col-md-4 mb-3">
                    <label>Quilómetros (Km)</label>
                    <input asp-for="NewCar.Kilometers" class="form-control input-premium" type="number" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label>Portas</label>
                    <select class="form-control input-premium">
                        <option value="2">2 Portas</option>
                        <option value="3">3 Portas</option>
                        <option value="4">4 Portas</option>
                        <option value="5">5 Portas</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label>Cavalos (CV)</label>
                    <input type="number" class="form-control input-premium" placeholder="Ex: 600" />
                </div>
                <div class="col-md-4 mb-3">
                    <label>Cor Exterior</label>
                    <input type="text" class="form-control input-premium" placeholder="Ex: Nero Nemesis" />
                </div>
            </div>

            <div class="form-section-title">Visual e Matrícula</div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Matrícula</label>
                    <input asp-for="NewCar.PlateNumber" class="form-control input-premium" placeholder="00-XX-00" />
                </div>
                <div class="col-md-6 mb-3">
                    <label>URL da Imagem Principal</label>
                    <input asp-for="NewCar.ImageUrl" class="form-control input-premium" placeholder="https://..." />
                </div>
            </div>

            <button type="submit" class="btn-publish-luxury">
                Confirmar e Publicar Anúncio
            </button>
        </form>
    </div>
</div>