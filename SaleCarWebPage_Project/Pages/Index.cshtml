@page
@model IndexModel
@{
    ViewData["Title"] = "Explorar Coleção";
}

@section Styles {
    <link rel="stylesheet" href="~/css/global/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/global/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/index.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body, .luxury-theme, .main-content, .home-container {
            background: transparent !important;
        }

        .search-section {
            background: rgba(20, 20, 20, 0.4) !important;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 40px;
        }

        .car-card {
            background: rgba(15, 15, 15, 0.3) !important;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.08) !important;
            position: relative;
            overflow: hidden;
            border-radius: 15px;
            transition: transform 0.3s ease;
        }

        .car-card:hover {
            transform: translateY(-5px);
            border-color: rgba(212, 175, 55, 0.4) !important;
        }

        .card-info {
            background: linear-gradient(transparent, rgba(0,0,0,0.9) 70%) !important;
        }

        .section-title, .card-header h3 {
            color: white !important;
            text-shadow: 0 4px 10px rgba(0,0,0,0.8);
        }

        .filter-group label {
            color: #d4af37 !important;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 1px;
        }

        /* --- DESIGN BOTÃO DE GARAGEM PREMIUM --- */
        .premium-garage-wrapper {
            position: absolute;
            top: 15px;
            right: 15px;
            z-index: 20;
        }

        .btn-garage {
            background: rgba(0, 0, 0, 0.6);
            border: 1px solid #d4af37;
            color: #d4af37;
            width: 45px;
            height: 45px;
            border-radius: 10px;
            cursor: pointer;
            backdrop-filter: blur(5px);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

            .btn-garage.is-in-garage {
                background: linear-gradient(135deg, #d4af37 0%, #f1c40f 100%);
                color: #000;
                box-shadow: 0 0 15px rgba(212, 175, 55, 0.5);
                border: none;
            }

            .btn-garage:hover {
                transform: scale(1.1);
                border-color: #fff;
            }

            .btn-garage i {
                font-size: 1.2rem;
            }
    </style>
}

<div class="home-container">
    <form method="get">
        <section class="search-section">
            <div class="search-container">
                <div class="main-search">
                    <ion-icon name="search-outline" style="color: white;"></ion-icon>
                    <input type="text" asp-for="SearchTerm" placeholder="Pesquise por modelo (ex: Ferrari 488)..." style="color: white; background: transparent; border: none; outline: none; width: 100%;" />
                    <button type="submit" class="btn-premium">Procurar</button>
                </div>

                <div class="filter-grid">
                    <div class="filter-group">
                        <label>Localização</label>
                        <select asp-for="Location">
                            <option value="">Portugal Inteiro</option>
                            <option value="Lisboa">Lisboa</option>
                            <option value="Porto">Porto</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Marca</label>
                        <select asp-for="BrandId" asp-items="Model.BrandList">
                            <option value="">Todas as Marcas</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Tipo</label>
                        <select asp-items="Model.TypeList">
                            <option value="">Todos os Tipos</option>
                        </select>
                    </div>
                </div>
            </div>
        </section>
    </form>

    <section class="cars-display">
        <h2 class="section-title">Destaques Premium</h2>

        <div class="cars-grid">

            @* --- LOOP DA BASE DE DADOS --- *@
            @if (Model.Cars != null)
            {
                @foreach (var car in Model.Cars)
                {
                    <div class="car-card">
                        <div class="premium-garage-wrapper">
                            <button class="btn-garage @(car.IsFavorite ? "is-in-garage" : "")"
                                    onclick="toggleGarage(@car.CarId, this)">
                                <i class="@(car.IsFavorite ? "fa-solid fa-gem" : "fa-regular fa-gem")"></i>
                            </button>
                        </div>
                        <div class="card-image">
                            <img src="@car.ImageUrl" alt="Car Image">
                        </div>
                        <div class="card-info">
                            <div class="card-header">
                                <h3>@car.PlateNumber</h3>
                                <span class="price">@car.CarPrice.ToString("N0")€</span>
                            </div>
                            <div class="card-details">
                                <p><ion-icon name="location-outline"></ion-icon> @car.Location</p>
                                <p><ion-icon name="speedometer-outline"></ion-icon> @car.Kilometers km • @car.Year</p>
                                <a href="/Cars/Details/@car.CarId" class="btn-view">Ver Detalhes</a>
                            </div>
                        </div>
                    </div>
                }
            }

            @* --- CARROS ESTÁTICOS (DESIGN REFERENCE) --- *@
            <div class="car-card">
                <div class="premium-garage-wrapper">
                    <button class="btn-garage" onclick="toggleGarage(0, this)">
                        <i class="fa-regular fa-gem"></i>
                    </button>
                </div>
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1592198084033-aade902d1aae?auto=format&fit=crop&w=800" alt="Ferrari">
                </div>
                <div class="card-info">
                    <div class="card-header">
                        <h3>Ferrari F8 Tributo</h3>
                        <span class="price">340.000€</span>
                    </div>
                    <div class="card-details">
                        <p><ion-icon name="location-outline"></ion-icon> Lisboa, Portugal</p>
                        <p><ion-icon name="speedometer-outline"></ion-icon> 2.500 km • 720 cv</p>
                        <a href="#" class="btn-view">Ver Detalhes</a>
                    </div>
                </div>
            </div>

            <div class="car-card">
                <div class="premium-garage-wrapper">
                    <button class="btn-garage" onclick="toggleGarage(-1, this)">
                        <i class="fa-regular fa-gem"></i>
                    </button>
                </div>
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=800" alt="Porsche">
                </div>
                <div class="card-info">
                    <div class="card-header">
                        <h3>Porsche 911 GT3</h3>
                        <span class="price">215.000€</span>
                    </div>
                    <div class="card-details">
                        <p><ion-icon name="location-outline"></ion-icon> Porto, Portugal</p>
                        <p><ion-icon name="speedometer-outline"></ion-icon> 1.200 km • 510 cv</p>
                        <a href="#" class="btn-view">Ver Detalhes</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        async function toggleGarage(carId, btn) {
            if (carId <= 0) {
                alert("Este é um carro de demonstração.");
                return;
            }

            try {
                const response = await fetch(`/Cars/ToggleFavorite?carId=${carId}`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (response.ok) {
                    const icon = btn.querySelector('i');
                    btn.classList.toggle('is-in-garage');

                    if (btn.classList.contains('is-in-garage')) {
                        icon.classList.replace('fa-regular', 'fa-solid');
                    } else {
                        icon.classList.replace('fa-solid', 'fa-regular');
                    }
                } else if (response.status === 401) {
                    alert("Por favor, faça login para adicionar carros à sua garagem privada.");
                    window.location.href = '/Identity/Account/Login';
                }
            } catch (error) {
                console.error("Erro na ligação à garagem:", error);
            }
        }
    </script>
}