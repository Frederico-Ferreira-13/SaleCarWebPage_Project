@page
@model IndexModel
@{
    ViewData["Title"] = "Explorar Coleção";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/car_card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/favoritesBottom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}

<div class="home-container">
    @* --- SECÇÃO DE FILTROS --- *@
    <form method="get">
        <section class="search-section">
            <div class="search-container">
                <div class="main-search">
                    <i class="fa-solid fa-magnifying-glass" style="color: var(--silver-main); margin-left: 15px;"></i>
                    <input type="text" asp-for="SearchTerm" placeholder="Pesquise por modelo (ex: Ferrari 488)..." />
                    <button type="submit" class="btn-premium">Procurar</button>
                </div>

                <div class="filter-grid">
                    <div class="filter-group">
                        <label>Localização</label>
                        <select asp-for="Location" onchange="this.form.submit()">
                            <option value="">Portugal Inteiro</option>
                            <option value="Lisboa">Lisboa</option>
                            <option value="Porto">Porto</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Marca</label>
                        <select asp-for="BrandId" asp-items="Model.BrandList" onchange="this.form.submit()">
                            <option value="">Todas as Marcas</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Combustível</label>
                        <select asp-for="FuelTypeSelected" asp-items="Model.FuelList" onchange="this.form.submit()">
                            <option value="">Todos os Motores</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Transmissão</label>
                        <select asp-for="Transmission" asp-items="Model.TransmissionList" onchange="this.form.submit()">
                            <option value="">Todas as Caixas</option>
                        </select>
                    </div>
                </div>
            </div>
        </section>
    </form>

    @* --- GRID DE CARROS --- *@
    <section class="cars-display">
        <h2 class="section-title">Destaques Premium</h2>

        <div class="cars-grid">
            @if (Model.Cars != null && Model.Cars.Any())
            {
                @foreach (var car in Model.Cars)
                {
                    <div class="car-card">
                        <div class="premium-garage-wrapper">
                            <button class="btn-garage @(car.IsFavorite ? "is-in-garage" : "")"
                                    onclick="toggleGarage(@car.CarId, this)">
                                <i class="@(car.IsFavorite ? "fa-solid fa-gem" : "fa-regular fa-gem")"></i>
                            </button>
                        </div>

                        <div class="card-image">
                            <img src="@(string.IsNullOrEmpty(car.ImageUrl) ? "/img/no-car.png" : car.ImageUrl)" alt="Carro">
                        </div>

                        <div class="card-info">
                            <div class="card-header">
                                <h3>@(car.Model?.Brand?.BrandName) @(car.Model?.ModelName)</h3>
                                <span class="price">@car.CarPrice.ToString("N0") €</span>
                            </div>

                            <div class="card-details">
                                <p><i class="fa-solid fa-location-dot"></i> @(car.Provider?.Address?.City ?? "Portugal")</p>
                                <p><i class="fa-solid fa-gauge-high"></i> @car.Kilometers.ToString("N0") km • @car.Year</p>

                                <div class="card-actions">
                                    <a href="/viewCar/@car.CarId" class="btn-card-primary">
                                        <i class="fa-solid fa-eye"></i> Detalhes
                                    </a>                                    
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        async function toggleGarage(carId, btn) {
            // Verifica se o utilizador está logado antes de tentar o AJAX
            const isAuthenticated = @(User.Identity.IsAuthenticated.ToString().ToLower());

            if (!isAuthenticated) {
                toastr.warning("Por favor, faça login para guardar carros nos seus favoritos.");
                setTimeout(() => { window.location.href = '/auth'; }, 2000);
                return;
            }

            if (carId <= 0) return;

            try {
                const response = await fetch(`?handler=ToggleFavorite&carId=${carId}`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                if (response.ok) {
                    const icon = btn.querySelector('i');
                    btn.classList.toggle('is-in-garage');

                    if (btn.classList.contains('is-in-garage')) {
                        icon.classList.replace('fa-regular', 'fa-solid');
                        toastr.success("Adicionado aos favoritos!");
                    } else {
                        icon.classList.replace('fa-solid', 'fa-regular');
                        toastr.info("Removido dos favoritos.");
                    }
                }
            } catch (error) {
                console.error("Erro na ligação:", error);
            }
        }
    </script>
}