@page
@model IndexModel
@{
    ViewData["Title"] = "Explorar Coleção";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}

<div class="home-container">
    <form method="get">
        <section class="search-section">
            <div class="search-container">
                <div class="main-search">
                    <ion-icon name="search-outline" style="color: white;"></ion-icon>
                    <input type="text" asp-for="SearchTerm" placeholder="Pesquise por modelo (ex: Ferrari 488)..." style="color: white; background: transparent; border: none; outline: none; width: 100%;" />
                    <button type="submit" class="btn-premium">Procurar</button>
                </div>

                <div class="filter-grid">
                    <div class="filter-group">
                        <label>Localização</label>
                        <select asp-for="Location" onchange="this.form.submit()">
                            <option value="">Portugal Inteiro</option>
                            <option value="Lisboa">Lisboa</option>
                            <option value="Porto">Porto</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Marca</label>
                        <select asp-for="BrandId" asp-items="Model.BrandList" onchange="this.form.submit()">
                            <option value="">Todas as Marcas</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Combustível</label>
                        <select asp-for="FuelTypeSelected" asp-items="Model.FuelList" onchange="this.form.submit()">
                            <option value="">Todos os Motores</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Transmissão</label>
                        <select asp-for="Transmission" asp-items="Model.TransmissionList" onchange="this.form.submit()">
                            <option value="">Todas as Caixas</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Tipo</label>
                        <select asp-for="CarType" asp-items="Model.TypeList" onchange="this.form.submit()">
                            <option value="">Todos os Estilos</option>
                        </select>
                    </div>
                </div>
            </div>
        </section>
    </form>

    <section class="cars-display">
        <h2 class="section-title">Destaques Premium</h2>

        <div class="cars-grid">
            @if (Model.Cars != null && Model.Cars.Any())
            {
                @foreach (var car in Model.Cars)
                {
                    <div class="car-card">
                        <div class="premium-garage-wrapper">
                            <button class="btn-garage @(car.IsFavorite ? "is-in-garage" : "")"
                                    onclick="toggleGarage(@car.CarId, this)">
                                <i class="@(car.IsFavorite ? "fa-solid fa-gem" : "fa-regular fa-gem")"></i>
                            </button>
                        </div>
                        <div class="card-image">
                            <img src="@car.ImageUrl" alt="Car Image">
                        </div>
                        <div class="card-info">
                            <div class="card-header">
                                <h3>@(car.Model?.Brand?.BrandName) @(car.Model?.ModelName)</h3>
                                <span class="price">@car.CarPrice.ToString("N0")€</span>
                            </div>
                            <div class="card-details">
                                <p>
                                    <ion-icon name="location-outline"></ion-icon>
                                    @(car.Provider?.Address?.City ?? "Portugal")
                                </p>
                                <p><ion-icon name="speedometer-outline"></ion-icon> @car.Kilometers km • @car.Year</p>
                                <a href="/Cars/Details/@car.CarId" class="btn-view">Ver Detalhes</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="no-results">
                    <p>Nenhum carro encontrado com os critérios selecionados.</p>
                </div>
            }
        </div>
    </section>
</div>

@* Adicionamos o token de segurança para o POST AJAX funcionar *@
@Html.AntiForgeryToken()

@section Scripts {
    <script>
        async function toggleGarage(carId, btn) {
            if (carId <= 0) {
                alert("Este é um carro de demonstração.");
                return;
            }

            try {
                // Alterado para chamar o Handler OnPostToggleFavorite na mesma página
                const response = await fetch(`?handler=ToggleFavorite&carId=${carId}`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        // Importante: Envia o token de segurança do .NET
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                if (response.ok) {
                    const icon = btn.querySelector('i');
                    btn.classList.toggle('is-in-garage');

                    if (btn.classList.contains('is-in-garage')) {
                        icon.classList.replace('fa-regular', 'fa-solid');
                    } else {
                        icon.classList.replace('fa-solid', 'fa-regular');
                    }
                } else if (response.status === 401) {
                    alert("Por favor, faça login para adicionar carros à sua garagem privada.");
                    window.location.href = '/Identity/Account/Login';
                }
            } catch (error) {
                console.error("Erro na ligação à garagem:", error);
            }
        }
    </script>
}