@page
@model SaleCarWebPage_Project.Pages.profileModel
@{
    ViewData["Title"] = "O Meu Perfil";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/car_card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/profileEdit.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/styles.css" asp-append-version="true" />
}

<div class="profile-container">
    <header class="profile-header">
        <div class="profile-flex">
            <div class="profile-img-wrapper">
                @if (!string.IsNullOrEmpty(Model.CurrentUser?.ProfilePicture))
                {
                    <img src="@Model.CurrentUser.ProfilePicture" alt="Foto de Perfil" class="profile-img-large">
                }
                else
                {
                    <img src="~/img/user-default.png" alt="Foto de Perfil" class="profile-img-large">
                }
                <div class="status-badge">Membro VIP</div>
            </div>
    
            <div class="user-info">
                <span class="member-since">Membro desde @(Model.CurrentUser?.CreatedAt.ToString("yyyy") ?? "2024")</span>
                <h1>Olá, @(Model.CurrentUser?.Name ?? "Utilizador")!</h1>
        
                <div class="user-stats-grid">
                    <div class="stat-card">
                        <span class="stat-value">@Model.TotalAnnounced</span>
                        <span class="stat-label">Anúncios Ativos</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-value">@Model.TotalGarage</span>
                        <span class="stat-label">Na Garagem</span>
                    </div>
                </div>

                <div class="profile-actions">                    
                    <a asp-page="/profileEdit" class="btn-premium-outline">
                        <i class="fa-solid fa-user-gear"></i> Editar Dados
                    </a>
                    <a asp-page="/saleCar" class="btn-premium">
                        <i class="fa-solid fa-plus"></i> Novo Anúncio
                    </a>
                </div>
            </div>
        </div>
    </header>

        
    <main class="profile-content">
        <h2 class="section-title">
            <i class="fa-solid fa-car-side"></i> A Minha Coleção
        </h2>
    
        <div class="profile-grid">
            @if (Model.MyCars != null && Model.MyCars.Any())
            {
                @foreach (var car in Model.MyCars)
                {
                    <div class="car-card">
                        <div class="card-status-badge @(car.IsApproved ? "approved" : "pending")">
                            <i class="fa-solid @(car.IsApproved ? "fa-check-circle" : "fa-clock")"></i>
                            @(car.IsApproved ? "Publicado" : "Pendente")
                        </div>

                        <div class="card-image">
                            <img src="@(string.IsNullOrEmpty(car.ImageUrl) ? "/img/no-car.png" : car.ImageUrl)" alt="Imagem do Carro">
                        </div>
                        
                        <div class="card-info">
                            <div class="card-header">
                                <h3>@car.Model?.Brand?.BrandName @car.Model?.ModelName</h3>
                                <span class="price">@car.CarPrice.ToString("N0") €</span>
                            </div>

                            <div class="card-details">
                                <p><i class="fa-solid fa-calendar-days"></i> Ano: @car.Year</p>
                                <p><i class="fa-solid fa-gauge-high"></i> @car.Kilometers.ToString("N0") km</p>
                                
                                <div class="card-actions">
                                    <a href="/editSaleCar/@car.CarId" class="btn-card-secondary">
                                        <i class="fa-solid fa-pen"></i> Gerir
                                    </a>
                                    <a href="/viewCar/@car.CarId" class="btn-card-primary">
                                        <i class="fa-solid fa-eye"></i> Ver
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state-notice" style="grid-column: 1/-1; text-align: center; padding: 60px; background: rgba(255,255,255,0.02); border-radius: 20px; border: 1px dashed rgba(255,255,255,0.1);">
                    <i class="fa-solid fa-car" style="font-size: 3rem; color: rgba(255,255,255,0.1); margin-bottom: 20px;"></i>
                    <p style="color: white; opacity: 0.6;">Ainda não tens carros listados para venda.</p>
                    <a asp-page="/saleCar" class="btn-premium" style="margin-top: 20px; text-decoration: none; display: inline-block;">
                        Começar a Vender
                    </a>
                </div>
            }
        </div>
    </main>
</div>
    