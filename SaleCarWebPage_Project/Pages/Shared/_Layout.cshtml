@functions {
    public string IsActive(string page)
    {
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
        return string.Equals(currentPage, page, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
}
<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Luxury Cars</title>

    <link rel="stylesheet" href="~/css/global/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/global/styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
</head>
<body class="luxury-theme">

    <nav class="navigation">
        <ul>
            @* --- ITEM PÚBLICO --- *@
            <li class="list @IsActive("/Index")">
                <b></b><b></b>
                <a asp-page="/Index">
                    <span class="icon"><ion-icon name="compass-outline"></ion-icon></span>
                    <span class="title">Explorar</span>
                </a>
            </li>

            @* --- ITENS PRIVADOS (Qualquer utilizador logado) --- *@
            @if (User.Identity.IsAuthenticated)
            {
                <li class="list @IsActive("/Anunciar")">
                    <b></b><b></b>
                    <a asp-page="/Anunciar">
                        <span class="icon"><ion-icon name="add-circle-outline"></ion-icon></span>
                        <span class="title">Vender Carro</span>
                    </a>
                </li>
                <li class="list @IsActive("/Favoritos")">
                    <b></b><b></b>
                    <a asp-page="/Favoritos">
                        <span class="icon"><ion-icon name="heart-outline"></ion-icon></span>
                        <span class="title">Favoritos</span>
                    </a>
                </li>
                <li class="list @IsActive("/Messages/Index")">
                    <b></b><b></b>
                    <a asp-page="/Messages/Index">
                        <span class="icon"><ion-icon name="chatbubbles-outline"></ion-icon></span>
                        <span class="title">Mensagens</span>
                    </a>
                </li>

                @* --- ITEM EXCLUSIVO ADMIN (Aprovações Pendentes) --- *@
                @if (User.IsInRole("Admin"))
                {
                    <li class="list @IsActive("/Admin/Aprovacoes")">
                        <b></b><b></b>
                        <a asp-page="/Admin/Aprovacoes">
                            <span class="icon"><ion-icon name="checkmark-done-circle-outline"></ion-icon></span>
                            <span class="title">Aprovações</span>
                        </a>
                    </li>
                }
            }
        </ul>

        <ul class="nav-bottom" style="margin-bottom: 20px;">
            <li class="list @IsActive("/login")">
                <b></b><b></b>
                <a asp-page="/auth">
                    <span class="icon"><ion-icon name="person-outline"></ion-icon></span>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <span class="title">O Meu Perfil</span>
                    }
                    else
                    {
                        <span class="title">Entrar</span>
                    }
                </a>
            </li>
            
            @if (User.Identity.IsAuthenticated)
            {
                <li class="list">
                    <b></b><b></b>
                    <a asp-page="/Logout">
                        <span class="icon"><ion-icon name="log-out-outline"></ion-icon></span>
                        <span class="title">Sair</span>
                    </a>
                </li>
            }
        </ul>
    </nav>

    <div class="main-content">
        <header style="padding: 20px; text-align: right; display: flex; justify-content: flex-end; align-items: center; gap: 10px;">
            @if (User.Identity.IsAuthenticated)
            {
                <div style="display: flex; flex-direction: column; align-items: flex-end;">
                    <span style="color: var(--gold); font-weight: 500;">Olá, @User.Identity.Name</span>
                    @if (User.IsInRole("Admin"))
                    {
                        <small style="color: #ff4d4d; font-size: 0.7em; text-transform: uppercase; letter-spacing: 1px;">Administrador</small>
                    }
                </div>
                <div class="user-avatar" style="width: 35px; height: 35px; background: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--deep-black);">
                    <ion-icon name="person"></ion-icon>
                </div>
            }
        </header>
        
        <main role="main" class="container" style="padding: 20px;">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>