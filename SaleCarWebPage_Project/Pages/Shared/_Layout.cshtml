@functions {
    public string IsActive(string page)
    {
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
        return string.Equals(currentPage, page, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
}
<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Luxury Cars</title>

    <link rel="stylesheet" href="~/css/global/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/global/styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    @await RenderSectionAsync("Styles", required: false)

    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>
</head>
<body class="luxury-theme">

    <canvas id="smokeCanvas"></canvas>

    <nav class="navigation">
        <ul>
            <li class="list @IsActive("/Index")">
                <b></b><b></b>
                <a asp-page="/Index">
                    <span class="icon"><ion-icon name="compass-outline"></ion-icon></span>
                    <span class="title">Explorar</span>
                </a>
            </li>

            @if (User.Identity.IsAuthenticated)
            {
                <li class="list @IsActive("/dashboard")">
                    <b></b><b></b>
                    <a asp-page="/dashboard">
                        <span class="icon"><ion-icon name="speedometer-outline"></ion-icon></span>
                        <span class="title">Dashboard</span>
                    </a>
                </li>
                <li class="list @IsActive("/SaleCar")">
                    <b></b><b></b>
                    <a asp-page="/saleCar">
                        <span class="icon"><ion-icon name="add-circle-outline"></ion-icon></span>
                        <span class="title">Anunciar</span>
                    </a>
                </li>
                <li class="list @IsActive("/myfavoritesCar")">
                    <b></b><b></b>
                    <a asp-page="/myfavoritesCar">
                        <span class="icon"><ion-icon name="diamond-outline"></ion-icon></span>
                        <span class="title">Favoritos</span>
                    </a>
                </li>

                <li class="list @IsActive("/messagesPage")">
                    <b></b><b></b>
                    <a asp-page="/messagesPage">
                        <span class="icon"><ion-icon name="chatbubbles-outline"></ion-icon></span>
                        <span class="title">Mensagens</span>
                    </a>
                </li>

                <li class="list @IsActive("/Negotiations")">
                    <b></b><b></b>
                    <a asp-page="/Negotiations">
                        <span class="icon"><i class="fa-solid fa-handshake"></i></span>
                        <span class="title">Negociações</span>
                    </a>
                </li>

                @if (User.IsInRole("1") || User.IsInRole("Admin"))
                {
                    <li class="list @IsActive("/pendingCar")">
                        <b></b><b></b>
                        <a asp-page="/pendingCar">
                            <span class="icon"><ion-icon name="checkmark-done-circle-outline"></ion-icon></span>
                            <span class="title">Aprovações</span>
                        </a>
                    </li>
                }
            }
        </ul>

        <ul class="nav-bottom" style="margin-bottom: 20px;">
            @if (!User.Identity.IsAuthenticated)
            {
                <li class="list @IsActive("/auth")">
                    <b></b><b></b>
                    <a asp-page="/auth">
                        <span class="icon"><ion-icon name="person-outline"></ion-icon></span>
                        <span class="title">Entrar</span>
                    </a>
                </li>
            }
            else
            {
                <li class="list @IsActive("/settings")">
                    <b></b><b></b>
                    <a asp-page="/settings">
                        <span class="icon"><ion-icon name="settings-outline"></ion-icon></span>
                        <span class="title">Definições</span>
                    </a>
                </li>

                <li class="list @IsActive("/profile")">
                    <b></b><b></b>
                    <a asp-page="/profile">
                        <span class="icon"><ion-icon name="person-outline"></ion-icon></span>
                        <span class="title">O Meu Perfil</span>
                    </a>
                </li>

                <li class="list">
                    <b></b><b></b>
                    <a asp-page="/Logout">
                        <span class="icon"><ion-icon name="log-out-outline"></ion-icon></span>
                        <span class="title">Sair</span>
                    </a>
                </li>
            }
        </ul>
    </nav>

    <div class="main-content">
        <header style="padding: 20px; text-align: right; display: flex; justify-content: flex-end; align-items: center; gap: 10px;">
            @if (User.Identity.IsAuthenticated)
            {
                <div style="display: flex; flex-direction: column; align-items: flex-end;">
                    <span style="color: #d4af37; font-weight: 500;">Olá, @User.Identity.Name</span>
                    @if (User.IsInRole("1") || User.IsInRole("Admin"))
                    {
                        <small style="color: #ff4d4d; font-size: 0.7em; text-transform: uppercase;">Administrador</small>
                    }
                </div>
                <a asp-page="/profile" class="user-avatar" style="width: 35px; height: 35px; background: #d4af37; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #000; text-decoration: none;">
                    <ion-icon name="person"></ion-icon>
                </a>
            }
        </header>

        <main role="main" class="container" style="padding: 20px;">
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function() {
            @if (TempData["Success"] != null)
            {
                <text>toastr.success('@TempData["Success"]');</text>
            }
            @if (TempData["Error"] != null)
            {
                <text>toastr.error('@TempData["Error"]');</text>
            }
            @if (TempData["Info"] != null)
            {
                <text>toastr.info('@TempData["Info"]');</text>
            }
        });
    </script>

    <script>
        (function () {
            const canvas = document.getElementById('smokeCanvas');
            const ctx = canvas.getContext('2d');

            canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:-1;pointer-events:none;background:#050505;';

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', resize);

            const particles = [];
            const SPAWN_POINTS = [0.1, 0.3, 0.5, 0.7, 0.9];

            function Particle(xPercent) {
                this.reset = function (xPct) {
                    this.x = canvas.width * xPct + (Math.random() - 0.5) * 60;
                    this.y = canvas.height + Math.random() * 80;
                    this.radius = 30 + Math.random() * 60;
                    this.maxRadius = 180 + Math.random() * 200;
                    this.opacity = 0;
                    this.maxOpacity = 0.04 + Math.random() * 0.07;
                    this.speedY = 0.4 + Math.random() * 0.6;
                    this.speedX = (Math.random() - 0.5) * 0.4;
                    this.growSpeed = 0.5 + Math.random() * 0.8;
                    this.fadeInDist = canvas.height * 0.15;
                    this.fadeOutDist = canvas.height * 0.35;
                    this.startY = this.y;
                    this.xPct = xPct;
                    this.grayVal = 100 + Math.floor(Math.random() * 80);
                };
                this.reset(xPercent);
                this.y = Math.random() * canvas.height;
                this.opacity = Math.random() * this.maxOpacity;
            }

            Particle.prototype.update = function () {
                this.y -= this.speedY;
                this.x += this.speedX;
                this.radius = Math.min(this.radius + this.growSpeed, this.maxRadius);

                const distFromBottom = this.startY - this.y;

                if (distFromBottom < this.fadeInDist) {
                    this.opacity = (distFromBottom / this.fadeInDist) * this.maxOpacity;
                } else if (this.y < this.fadeOutDist) {
                    this.opacity = (this.y / this.fadeOutDist) * this.maxOpacity;
                } else {
                    this.opacity = this.maxOpacity;
                }

                if (this.y < -this.maxRadius) {
                    this.reset(SPAWN_POINTS[Math.floor(Math.random() * SPAWN_POINTS.length)]);
                }
            };

            Particle.prototype.draw = function () {
                const g = this.grayVal;
                const grad = ctx.createRadialGradient(
                    this.x, this.y, 0,
                    this.x, this.y, this.radius
                );
                grad.addColorStop(0,   `rgba(${g},${g},${g},${this.opacity})`);
                grad.addColorStop(0.4, `rgba(${g},${g},${g},${this.opacity * 0.6})`);
                grad.addColorStop(1,   `rgba(${g},${g},${g},0)`);

                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = grad;
                ctx.fill();
            };

            SPAWN_POINTS.forEach(xPct => {
                for (let i = 0; i < 6; i++) {
                    particles.push(new Particle(xPct));
                }
            });

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = '#050505';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                particles.forEach(p => {
                    p.update();
                    p.draw();
                });

                requestAnimationFrame(animate);
            }

            animate();
        })();
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* RODAPÉ DE COPYRIGHT *@
    <footer>
        <i class="fa-solid fa-shield-halved text-gold"></i>
        &nbsp; &copy; @DateTime.Now.Year Luxury Cars &mdash; Desenvolvido por
        <span class="highlight">Frederico Ferreira</span>
        &amp;
        <span class="highlight">Fábio Salgado</span>.
        Todos os direitos reservados.
    </footer>

    <div id="gdpr-banner" style="position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
        background: rgba(15, 15, 15, 0.9); backdrop-filter: blur(10px);
        border: 1px solid var(--border-subtle); padding: 12px 25px; border-radius: 50px;
        display: flex; align-items: center; gap: 20px; z-index: 9999; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">

        <span style="color: var(--white); font-size: 0.8rem; white-space: nowrap;">
            Utilizamos cookies para garantir a melhor experiência premium.
            <a href="/Privacy" style="color: var(--gold); text-decoration: none; font-weight: bold;">Saber mais.</a>
        </span>

        <button onclick="acceptGDPR()" style="background: var(--gold-gradient); border: none; padding: 5px 15px;
            border-radius: 20px; font-size: 0.7rem; font-weight: 800; cursor: pointer; text-transform: uppercase;">
            Aceitar
        </button>
    </div>

    <script>
        function acceptGDPR() {
            localStorage.setItem('gdpr_accepted', 'true');
            document.getElementById('gdpr-banner').style.display = 'none';
        }

        document.addEventListener("DOMContentLoaded", function() {
            if (localStorage.getItem('gdpr_accepted') === 'true') {
                document.getElementById('gdpr-banner').style.display = 'none';
            }
        });
    </script>

</body>
</html>