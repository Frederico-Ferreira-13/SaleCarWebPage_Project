@model SaleCarWebPage_Project.Pages.Shared._messageBoxModel
@using System.Security.Claims
@{
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<div class="message-box-wrapper">
    <div class="message-header">
        <h4><i class="fa-solid fa-comments"></i> Mensagens</h4>
    </div>

    <div class="chat-conversation" id="chat-container">
        @if (Model.ChatHistory != null && Model.ChatHistory.Any())
        {
            @foreach (var mainMsg in Model.ChatHistory.Where(m => m.ParentMessageId == null).OrderBy(x => x.SentDate))
            {
                bool isMeMain = currentUserId == mainMsg.SenderId.ToString();

                <div class="thread-group mb-4" style="border-bottom: 1px solid #eee; padding-bottom: 10px;">
                    @* MENSAGEM RAIZ *@
                    <div class="chat-bubble @(isMeMain ? "bubble-sender" : "bubble-receiver")">
                        <small class="d-block fw-bold">@mainMsg.Subject</small>
                        <p>@mainMsg.MessageText</p>
                        <time class="msg-date">@mainMsg.SentDate.ToString("dd/MM HH:mm")</time>
                    </div>

                    @* RESPOSTAS *@
                    @{
                        var replies = Model.ChatHistory.Where(r => r.ParentMessageId == mainMsg.MessageBoxId).OrderBy(r => r.SentDate);
                    }
                    @foreach (var reply in replies)
                    {
                        bool isMeReply = currentUserId == reply.SenderId.ToString();
                        <div class="replies-container" style="margin-left: 30px; border-left: 2px solid #d4af37; padding-left: 10px;">
                            <div class="chat-bubble @(isMeReply ? "bubble-sender" : "bubble-receiver")">
                                <p>@reply.MessageText</p>
                                <time class="msg-date">@reply.SentDate.ToString("HH:mm")</time>
                            </div>
                        </div>
                    }

                    @* BOTÃO RESPONDER (Aparece para o Dono ou Comprador responderem um ao outro) *@
                    <div class="text-end mt-1">
                        <button type="button" class="btn btn-sm btn-link text-gold" onclick="prepareReply(@mainMsg.MessageBoxId, '@mainMsg.Subject')">
                            <i class="fa-solid fa-reply"></i> Responder
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-chat text-center p-4">
                <p>Nenhuma mensagem encontrada.</p>
            </div>
        }
    </div>

    @if (isAuthenticated)
    {
        <div class="chat-input-area mt-3">
            <form method="post"
                  asp-page="/viewCar"
                  asp-page-handler="SendMessage"
                  asp-route-id="@Model.CarId">
                @Html.AntiForgeryToken()
                
                @* CAMPOS HIDDEN PARA O BINDING NO C# *@
                <input type="hidden" name="CarId" value="@Model.CarId" />
                <input type="hidden" name="ParentMessageId" id="parentMessageIdField" value="" />

                @* INDICADOR DE RESPOSTA *@
                <div id="reply-indicator" style="display:none;" class="alert alert-warning py-1 px-2 mb-2">
                    <small>A responder a: <strong id="reply-subject"></strong></small>
                    <button type="button" class="btn-close btn-sm float-end" onclick="cancelReply()"></button>
                </div>

                <div class="msg-input-group">
                    <textarea name="MessageText" id="txtMessage" class="form-control" placeholder="Escreva a sua mensagem..." required></textarea>
                </div>

                <button type="submit" class="btn btn-dark w-100 mt-2">
                    <i class="fa-solid fa-paper-plane"></i> ENVIAR
                </button>
            </form>
        </div>
    }
</div>

<script>
    function prepareReply(parentId, subject) {
        document.getElementById('parentMessageIdField').value = parentId;
        document.getElementById('reply-subject').innerText = subject;
        document.getElementById('reply-indicator').style.display = 'block';
        document.getElementById('txtMessage').focus();
    }

    function cancelReply() {
        document.getElementById('parentMessageIdField').value = '';
        document.getElementById('reply-indicator').style.display = 'none';
    }
</script>
