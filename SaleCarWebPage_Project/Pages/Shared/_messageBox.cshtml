@model SaleCarWebPage_Project.Pages.Shared._messageBoxModel
@using System.Security.Claims
@{
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<div class="message-box-wrapper">
    <div class="message-header">
        <h4><i class="fa-solid fa-comments"></i> Contactar Vendedor</h4>
        <p class="header-subtitle">Tire as suas dúvidas sobre este veículo</p>
    </div>

    <div class="chat-conversation" id="chat-container">
        @if (Model.ChatHistory != null && Model.ChatHistory.Any())
        {
            @foreach (var msg in Model.ChatHistory.OrderBy(x => x.SentDate))
            {
                bool isMe = currentUserId == msg.SenderId.ToString();
                
                <div class="chat-bubble @(isMe ? "bubble-sender" : "bubble-receiver")">
                    @if (msg.IsDeleted)
                    {
                        <p class="deleted-msg"><i class="fa-solid fa-ban"></i> @msg.MessageText</p>
                    }
                    else
                    {
                        <p>@msg.MessageText</p>
                    }
                    <time class="msg-date">
                        @msg.SentDate.ToString("dd/MM HH:mm")
                        @if (isMe)
                        {
                            <span class="read-status">
                                <i class="fa-solid @(msg.IsRead ? "fa-check-double" : "fa-check")"></i>
                            </span>
                        }
                    </time>
                </div>
            }
        }
        else
        {
            <div class="empty-chat">
                <i class="fa-solid fa-comment-dots"></i>
                <p>Ainda não iniciou conversa para este anúncio.</p>
            </div>
        }
    </div>

    @if (isAuthenticated)
    {
        <div class="chat-input-area">
            <form method="post" asp-page-handler="SendMessage">
                @Html.AntiForgeryToken()
                <div class="msg-input-group">
                    <label><i class="fa-solid fa-pen-nib"></i> SUA MENSAGEM</label>
                    <textarea name="MessageText"
                              class="msg-control"
                              placeholder="Escreva aqui as suas questões..."
                              required></textarea>
                </div>

                <button type="submit" class="btn-gold-action">
                    <i class="fa-solid fa-paper-plane"></i> ENVIAR MENSAGEM
                </button>
            </form>
        </div>
    }
    else
    {
        <div class="login-prompt-msg">
            <p><a href="/auth">Inicie sessão</a> para contactar o vendedor.</p>
        </div>
    }
</div>
